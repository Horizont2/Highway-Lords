--- !u!114 &351459170
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 351459169}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: beacc1e1d00c42448ada932e2505f9ae, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::TutorialManager
  tutorialCanvas: {fileID: 351459169}
  darkOverlay: {fileID: 1262052743}
  dialogText: {fileID: 485071415}
  pointerHand: {fileID: 1240660488}
  dialogPanel: {fileID: 442249805}
  pointerOffset: {x: 90, y: 80}
  bounceDirection: {x: 0, y: 1}
  steps:
  - dialogText: Greetings, <color=#FFD700>Commander</color>! Our outpost on the Empire's
      border is under threat. The barbarians are preparing to attack, and we need
      defenders! Click here to hire a Swordsman."
    targetUI: {fileID: 1682400190}
    trigger: 0
    waitDuration: 3
    pauseGame: 0
  - dialogText: '"Roman steel is ready for battle. Give the order to hold the line
      and start the first wave!"'
    targetUI: {fileID: 1085086038}
    trigger: 0
    waitDuration: 3
    pauseGame: 0
  - dialogText: 
    targetUI: {fileID: 0}
    trigger: 1
    waitDuration: 3
    pauseGame: 0
  - dialogText: '"The first assault is repelled! The enemies are retreating. The
      Senate has sent us materials for fortification. Call for the imperial resource
      cart!"'
    targetUI: {fileID: 1015138363}
    trigger: 0
    waitDuration: 3
    pauseGame: 0
  - dialogText: Great! The cart is on its way. Let's wait until it delivers the wood
      and stone...
    targetUI: {fileID: 0}
    trigger: 3
    waitDuration: 15
    pauseGame: 0
  - dialogText: '"Resources delivered! To expand our garrison and hire more legionaries,
      we need new structures. Open the construction menu."'
    targetUI: {fileID: 683413340}
    trigger: 0
    waitDuration: 3
    pauseGame: 0
  - dialogText: '"Order the engineers to build a Barracks. This will increase the
      maximum number of troops on the battlefield."'
    targetUI: {fileID: 1143516057}
    trigger: 0
    waitDuration: 3
    pauseGame: 0
  - dialogText: '"Excellent work, Commander! Now you can grow your army and unlock
      new soldier classes. Defend this frontier in the name of Rome!\n(Tap anywhere
      to continue)"'
    targetUI: {fileID: 0}
    trigger: 5
    waitDuration: 3
    pauseGame: 0
  - dialogText: 
    targetUI: {fileID: 0}
    trigger: 4
    waitDuration: 3
    pauseGame: 0
  - dialogText: '"Attention, Commander! The barbarians have deployed Spearmen. They
      are deadly against our swordsmen and cavalry in close combat!\n\nA wise tactic
      is to hire Archers. They will rain arrows upon them from a distance. Always
      keep counter-classes in mind!\n(Tap the screen to resume the battle)"'
    targetUI: {fileID: 0}
    trigger: 5
    waitDuration: 3
    pauseGame: 0
  - dialogText: '"Click here to hire a squad of Archers!"'
    targetUI: {fileID: 145825452}
    trigger: 0
    waitDuration: 3
    pauseGame: 0
  - dialogText: 
    targetUI: {fileID: 0}
    trigger: 1
    waitDuration: 3
    pauseGame: 0
  - dialogText: '"Commander, basic weapons are no longer enough! The Emperor has
      sent 500 Gold to upgrade your troops."'
    targetUI: {fileID: 0}
    trigger: 8
    waitDuration: 500
    pauseGame: 1
  - dialogText: '"Open the Forge menu to improve your army."'
    targetUI: {fileID: 581305697}
    trigger: 0
    waitDuration: 3
    pauseGame: 1
  - dialogText: '"Upgrade the Knights'' equipment! This will increase their damage
      and health."'
    targetUI: {fileID: 1843171668}
    trigger: 0
    waitDuration: 3
    pauseGame: 1
  - dialogText: 
    targetUI: {fileID: 0}
    trigger: 1
    waitDuration: 3
    pauseGame: 0
  - dialogText: 
    targetUI: {fileID: 2028497864}
    trigger: 5
    waitDuration: 3
    pauseGame: 0
  - dialogText: '"We must strike back! It''s time to destroy the nearest barbarian
      camp. Open the Map."'
    targetUI: {fileID: 1095237823}
    trigger: 0
    waitDuration: 3
    pauseGame: 1
  - dialogText: 
    targetUI: {fileID: 583503655}
    trigger: 7
    waitDuration: 3
    pauseGame: 0
  - dialogText: '"To launch a siege, you need a Legion. Here is 700 Gold to fund
      your first campaign!"'
    targetUI: {fileID: 0}
    trigger: 8
    waitDuration: 700
    pauseGame: 1
  - dialogText: '"This is the Legion screen. Note: units that survive a siege or
      retreat safely will return to camp and join your next march for FREE!"'
    targetUI: {fileID: 0}
    trigger: 5
    waitDuration: 3
    pauseGame: 1
  - dialogText: '"First, hire a squad of Knights for your Vanguard."'
    targetUI: {fileID: 2028497864}
    trigger: 0
    waitDuration: 3
    pauseGame: 0
  - dialogText: '"Next, hire a squad of Archers for your Vanguard."'
    targetUI: {fileID: 2028497864}
    trigger: 5
    waitDuration: 3
    pauseGame: 0
  - dialogText: '"Excellent! Now give the order to attack the camp!"'
    targetUI: {fileID: 2028497864}
    trigger: 5
    waitDuration: 3
    pauseGame: 0
  currentStepIndex: 0
