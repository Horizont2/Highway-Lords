+#if UNITY_EDITOR
+using UnityEditor;
+using UnityEngine;
+using UnityEngine.UI;
+using TMPro;
+
+public static class CodexUIBuilder
+{
+    [MenuItem("Tools/Build Codex Panel UI")]
+    public static void BuildCodexPanel()
+    {
+        Canvas canvas = GetOrCreateCanvas();
+        if (canvas == null)
+        {
+            Debug.LogError("CodexUIBuilder: No Canvas found or created.");
+            return;
+        }
+
+        // Try to find existing CodexPanel under this Canvas
+        Transform codexPanelTr = canvas.transform.Find("CodexPanel");
+        GameObject codexPanel;
+        if (codexPanelTr != null)
+        {
+            codexPanel = codexPanelTr.gameObject;
+        }
+        else
+        {
+            codexPanel = CreateUIObject("CodexPanel", canvas.transform);
+            var img = codexPanel.AddComponent<Image>();
+            img.color = new Color(0f, 0f, 0f, 0.7f); // напівпрозорий чорний
+        }
+
+        RectTransform codexPanelRect = codexPanel.GetComponent<RectTransform>();
+        codexPanelRect.anchorMin = Vector2.zero;
+        codexPanelRect.anchorMax = Vector2.one;
+        codexPanelRect.offsetMin = Vector2.zero;
+        codexPanelRect.offsetMax = Vector2.zero;
+
+        // CodexContentPanel (parchment background)
+        GameObject contentPanel = GetOrCreateChild(codexPanel.transform, "CodexContentPanel");
+        var contentImg = contentPanel.GetComponent<Image>();
+        if (contentImg == null) contentImg = contentPanel.AddComponent<Image>();
+        contentImg.color = new Color(0.97f, 0.93f, 0.82f, 1f); // світлий "пергамент"
+
+        RectTransform contentRect = contentPanel.GetComponent<RectTransform>();
+        contentRect.anchorMin = new Vector2(0.1f, 0.1f);
+        contentRect.anchorMax = new Vector2(0.9f, 0.9f);
+        contentRect.offsetMin = Vector2.zero;
+        contentRect.offsetMax = Vector2.zero;
+
+        // CloseButton (top-right)
+        GameObject closeBtn = GetOrCreateChild(contentPanel.transform, "CloseButton");
+        Button closeButton = closeBtn.GetComponent<Button>();
+        if (closeButton == null) closeButton = closeBtn.AddComponent<Button>();
+        Image closeImg = closeBtn.GetComponent<Image>();
+        if (closeImg == null) closeImg = closeBtn.AddComponent<Image>();
+        closeImg.color = new Color(0.4f, 0.1f, 0.1f, 0.9f);
+
+        RectTransform closeRect = closeBtn.GetComponent<RectTransform>();
+        closeRect.anchorMin = new Vector2(1f, 1f);
+        closeRect.anchorMax = new Vector2(1f, 1f);
+        closeRect.pivot = new Vector2(1f, 1f);
+        closeRect.sizeDelta = new Vector2(40f, 40f);
+        closeRect.anchoredPosition = new Vector2(-10f, -10f);
+
+        TextMeshProUGUI closeText = GetOrCreateTMPChild(closeBtn.transform, "X");
+        closeText.alignment = TextAlignmentOptions.Center;
+        closeText.fontSize = 26f;
+        closeText.text = "X";
+
+        // LeftColumn (0 - 0.3)
+        GameObject leftColumn = GetOrCreateChild(contentPanel.transform, "LeftColumn");
+        RectTransform leftRect = leftColumn.GetComponent<RectTransform>();
+        leftRect.anchorMin = new Vector2(0f, 0f);
+        leftRect.anchorMax = new Vector2(0.3f, 1f);
+        leftRect.offsetMin = Vector2.zero;
+        leftRect.offsetMax = Vector2.zero;
+
+        // RightColumn (0.3 - 1)
+        GameObject rightColumn = GetOrCreateChild(contentPanel.transform, "RightColumn");
+        RectTransform rightRect = rightColumn.GetComponent<RectTransform>();
+        rightRect.anchorMin = new Vector2(0.3f, 0f);
+        rightRect.anchorMax = new Vector2(1f, 1f);
+        rightRect.offsetMin = Vector2.zero;
+        rightRect.offsetMax = Vector2.zero;
+
+        // --- LEFT COLUMN ---
+
+        // TabsContainer
+        GameObject tabsContainer = GetOrCreateChild(leftColumn.transform, "TabsContainer");
+        RectTransform tabsRect = tabsContainer.GetComponent<RectTransform>();
+        tabsRect.anchorMin = new Vector2(0f, 1f);
+        tabsRect.anchorMax = new Vector2(1f, 1f);
+        tabsRect.pivot = new Vector2(0.5f, 1f);
+        tabsRect.sizeDelta = new Vector2(0f, 40f);
+        tabsRect.anchoredPosition = new Vector2(0f, -10f);
+
+        var hlg = tabsContainer.GetComponent<HorizontalLayoutGroup>();
+        if (hlg == null) hlg = tabsContainer.AddComponent<HorizontalLayoutGroup>();
+        hlg.childControlWidth = true;
+        hlg.childControlHeight = true;
+        hlg.childForceExpandWidth = true;
+        hlg.childForceExpandHeight = true;
+        hlg.spacing = 5f;
+        hlg.padding = new RectOffset(5, 5, 0, 0);
+
+        CreateTabButton(tabsContainer.transform, "UnitsTabBtn", "Units");
+        CreateTabButton(tabsContainer.transform, "BuildingsTabBtn", "Buildings");
+        CreateTabButton(tabsContainer.transform, "EnemiesTabBtn", "Enemies");
+
+        // Scroll View for entries
+        GameObject scrollViewGO = GetOrCreateChild(leftColumn.transform, "Scroll View");
+        RectTransform scrollRectTr = scrollViewGO.GetComponent<RectTransform>();
+        scrollRectTr.anchorMin = new Vector2(0f, 0f);
+        scrollRectTr.anchorMax = new Vector2(1f, 1f);
+        scrollRectTr.offsetMin = new Vector2(10f, 10f);
+        scrollRectTr.offsetMax = new Vector2(-10f, -50f);
+
+        ScrollRect scrollRect = scrollViewGO.GetComponent<ScrollRect>();
+        if (scrollRect == null) scrollRect = scrollViewGO.AddComponent<ScrollRect>();
+
+        Image scrollImg = scrollViewGO.GetComponent<Image>();
+        if (scrollImg == null) scrollImg = scrollViewGO.AddComponent<Image>();
+        scrollImg.color = new Color(0f, 0f, 0f, 0.15f);
+
+        // Viewport
+        GameObject viewportGO = GetOrCreateChild(scrollViewGO.transform, "Viewport");
+        RectTransform viewportRect = viewportGO.GetComponent<RectTransform>();
+        viewportRect.anchorMin = Vector2.zero;
+        viewportRect.anchorMax = Vector2.one;
+        viewportRect.offsetMin = new Vector2(0f, 0f);
+        viewportRect.offsetMax = new Vector2(0f, 0f);
+
+        Mask mask = viewportGO.GetComponent<Mask>();
+        if (mask == null) mask = viewportGO.AddComponent<Mask>();
+        mask.showMaskGraphic = false;
+
+        Image viewportImg = viewportGO.GetComponent<Image>();
+        if (viewportImg == null) viewportImg = viewportGO.AddComponent<Image>();
+        viewportImg.color = new Color(1f, 1f, 1f, 0.01f);
+
+        // Content / EntryListContainer
+        GameObject contentGO = GetOrCreateChild(viewportGO.transform, "EntryListContainer");
+        RectTransform contentRT = contentGO.GetComponent<RectTransform>();
+        contentRT.anchorMin = new Vector2(0f, 1f);
+        contentRT.anchorMax = new Vector2(1f, 1f);
+        contentRT.pivot = new Vector2(0.5f, 1f);
+        contentRT.offsetMin = new Vector2(0f, 0f);
+        contentRT.offsetMax = new Vector2(0f, 0f);
+
+        VerticalLayoutGroup vlg = contentGO.GetComponent<VerticalLayoutGroup>();
+        if (vlg == null) vlg = contentGO.AddComponent<VerticalLayoutGroup>();
+        vlg.spacing = 5f;
+        vlg.childControlWidth = true;
+        vlg.childControlHeight = true;
+        vlg.childForceExpandWidth = true;
+        vlg.childForceExpandHeight = false;
+
+        ContentSizeFitter csf = contentGO.GetComponent<ContentSizeFitter>();
+        if (csf == null) csf = contentGO.AddComponent<ContentSizeFitter>();
+        csf.verticalFit = ContentSizeFitter.FitMode.PreferredSize;
+        csf.horizontalFit = ContentSizeFitter.FitMode.Unconstrained;
+
+        scrollRect.viewport = viewportRect;
+        scrollRect.content = contentRT;
+        scrollRect.horizontal = false;
+        scrollRect.vertical = true;
+
+        // --- RIGHT COLUMN ---
+
+        // TitleText
+        TextMeshProUGUI titleText = GetOrCreateTMPChild(rightColumn.transform, "TitleText");
+        RectTransform titleRect = titleText.rectTransform;
+        titleRect.anchorMin = new Vector2(0f, 1f);
+        titleRect.anchorMax = new Vector2(1f, 1f);
+        titleRect.pivot = new Vector2(0.5f, 1f);
+        titleRect.sizeDelta = new Vector2(0f, 40f);
+        titleRect.anchoredPosition = new Vector2(0f, -10f);
+        titleText.fontSize = 30f;
+        titleText.alignment = TextAlignmentOptions.Center;
+        titleText.text = "Unit Name";
+
+        // SubtitleText
+        TextMeshProUGUI subtitleText = GetOrCreateTMPChild(rightColumn.transform, "SubtitleText");
+        RectTransform subtitleRect = subtitleText.rectTransform;
+        subtitleRect.anchorMin = new Vector2(0f, 1f);
+        subtitleRect.anchorMax = new Vector2(1f, 1f);
+        subtitleRect.pivot = new Vector2(0.5f, 1f);
+        subtitleRect.sizeDelta = new Vector2(0f, 30f);
+        subtitleRect.anchoredPosition = new Vector2(0f, -50f);
+        subtitleText.fontSize = 20f;
+        subtitleText.alignment = TextAlignmentOptions.Center;
+        subtitleText.text = "Role / Faction";
+
+        // HeaderContainer (Portrait + Stats)
+        GameObject headerContainer = GetOrCreateChild(rightColumn.transform, "HeaderContainer");
+        RectTransform headerRect = headerContainer.GetComponent<RectTransform>();
+        headerRect.anchorMin = new Vector2(0f, 1f);
+        headerRect.anchorMax = new Vector2(1f, 1f);
+        headerRect.pivot = new Vector2(0.5f, 1f);
+        headerRect.sizeDelta = new Vector2(0f, 170f);
+        headerRect.anchoredPosition = new Vector2(0f, -90f);
+
+        HorizontalLayoutGroup headerHLG = headerContainer.GetComponent<HorizontalLayoutGroup>();
+        if (headerHLG == null) headerHLG = headerContainer.AddComponent<HorizontalLayoutGroup>();
+        headerHLG.spacing = 10f;
+        headerHLG.padding = new RectOffset(10, 10, 10, 10);
+        headerHLG.childControlWidth = false;
+        headerHLG.childControlHeight = true;
+        headerHLG.childForceExpandWidth = false;
+        headerHLG.childForceExpandHeight = true;
+
+        // PortraitImage
+        GameObject portraitGO = GetOrCreateChild(headerContainer.transform, "PortraitImage");
+        Image portraitImg = portraitGO.GetComponent<Image>();
+        if (portraitImg == null) portraitImg = portraitGO.AddComponent<Image>();
+        portraitImg.color = new Color(0f, 0f, 0f, 0.25f);
+
+        RectTransform portraitRect = portraitGO.GetComponent<RectTransform>();
+        portraitRect.sizeDelta = new Vector2(150f, 150f);
+
+        LayoutElement portraitLE = portraitGO.GetComponent<LayoutElement>();
+        if (portraitLE == null) portraitLE = portraitGO.AddComponent<LayoutElement>();
+        portraitLE.preferredWidth = 150f;
+        portraitLE.preferredHeight = 150f;
+        portraitLE.minWidth = 150f;
+        portraitLE.minHeight = 150f;
+
+        // StatsContainer
+        GameObject statsContainer = GetOrCreateChild(headerContainer.transform, "StatsContainer");
+        VerticalLayoutGroup statsVLG = statsContainer.GetComponent<VerticalLayoutGroup>();
+        if (statsVLG == null) statsVLG = statsContainer.AddComponent<VerticalLayoutGroup>();
+        statsVLG.spacing = 4f;
+        statsVLG.childControlWidth = true;
+        statsVLG.childControlHeight = true;
+        statsVLG.childForceExpandWidth = true;
+        statsVLG.childForceExpandHeight = false;
+
+        TextMeshProUGUI hpText = GetOrCreateTMPChild(statsContainer.transform, "HPText");
+        hpText.text = "HP: 100";
+        hpText.fontSize = 20f;
+        hpText.alignment = TextAlignmentOptions.Left;
+
+        TextMeshProUGUI dmgText = GetOrCreateTMPChild(statsContainer.transform, "DMGText");
+        dmgText.text = "DMG: 10";
+        dmgText.fontSize = 20f;
+        dmgText.alignment = TextAlignmentOptions.Left;
+
+        // DescriptionText
+        TextMeshProUGUI descriptionText = GetOrCreateTMPChild(rightColumn.transform, "DescriptionText");
+        RectTransform descRect = descriptionText.rectTransform;
+        descRect.anchorMin = new Vector2(0f, 0.25f);
+        descRect.anchorMax = new Vector2(1f, 0.75f);
+        descRect.offsetMin = new Vector2(10f, 10f);
+        descRect.offsetMax = new Vector2(-10f, -10f);
+        descriptionText.alignment = TextAlignmentOptions.TopLeft;
+        descriptionText.enableWordWrapping = true;
+        descriptionText.text = "Short description of the selected entry.";
+
+        // TacticsContainer
+        GameObject tacticsContainer = GetOrCreateChild(rightColumn.transform, "TacticsContainer");
+        RectTransform tacticsRect = tacticsContainer.GetComponent<RectTransform>();
+        tacticsRect.anchorMin = new Vector2(0f, 0f);
+        tacticsRect.anchorMax = new Vector2(1f, 0.25f);
+        tacticsRect.offsetMin = new Vector2(10f, 10f);
+        tacticsRect.offsetMax = new Vector2(-10f, -10f);
+
+        HorizontalLayoutGroup tacticsHLG = tacticsContainer.GetComponent<HorizontalLayoutGroup>();
+        if (tacticsHLG == null) tacticsHLG = tacticsContainer.AddComponent<HorizontalLayoutGroup>();
+        tacticsHLG.spacing = 10f;
+        tacticsHLG.childControlWidth = true;
+        tacticsHLG.childControlHeight = true;
+        tacticsHLG.childForceExpandWidth = true;
+        tacticsHLG.childForceExpandHeight = true;
+
+        TextMeshProUGUI prosText = GetOrCreateTMPChild(tacticsContainer.transform, "ProsText");
+        prosText.text = "<b>Pros:</b> durable, good vs cavalry";
+        prosText.enableWordWrapping = true;
+        prosText.richText = true;
+        prosText.alignment = TextAlignmentOptions.TopLeft;
+
+        TextMeshProUGUI consText = GetOrCreateTMPChild(tacticsContainer.transform, "ConsText");
+        consText.text = "<b>Cons:</b> slow, weak vs archers";
+        consText.enableWordWrapping = true;
+        consText.richText = true;
+        consText.alignment = TextAlignmentOptions.TopLeft;
+
+        // --- Prefab CodexEntryBtn ---
+        CreateOrUpdateCodexEntryButtonPrefab();
+
+        Debug.Log("CodexUIBuilder: CodexPanel hierarchy built/updated.");
+    }
+
+    private static Canvas GetOrCreateCanvas()
+    {
+        Canvas canvas = Object.FindFirstObjectByType<Canvas>();
+        if (canvas != null) return canvas;
+
+        GameObject canvasGO = new GameObject("Canvas", typeof(RectTransform), typeof(Canvas), typeof(CanvasScaler), typeof(GraphicRaycaster));
+        canvas = canvasGO.GetComponent<Canvas>();
+        canvas.renderMode = RenderMode.ScreenSpaceOverlay;
+        CanvasScaler scaler = canvasGO.GetComponent<CanvasScaler>();
+        scaler.uiScaleMode = CanvasScaler.ScaleMode.ScaleWithScreenSize;
+        scaler.referenceResolution = new Vector2(1920, 1080);
+        scaler.screenMatchMode = CanvasScaler.ScreenMatchMode.MatchWidthOrHeight;
+        scaler.matchWidthOrHeight = 0.5f;
+        return canvas;
+    }
+
+    private static GameObject CreateUIObject(string name, Transform parent)
+    {
+        GameObject go = new GameObject(name, typeof(RectTransform));
+        go.transform.SetParent(parent, false);
+        return go;
+    }
+
+    private static GameObject GetOrCreateChild(Transform parent, string name)
+    {
+        Transform existing = parent.Find(name);
+        if (existing != null) return existing.gameObject;
+        return CreateUIObject(name, parent);
+    }
+
+    private static TextMeshProUGUI GetOrCreateTMPChild(Transform parent, string name)
+    {
+        Transform existing = parent.Find(name);
+        if (existing != null)
+        {
+            TextMeshProUGUI tmp = existing.GetComponent<TextMeshProUGUI>();
+            if (tmp != null) return tmp;
+        }
+
+        GameObject go = CreateUIObject(name, parent);
+        RectTransform rt = go.GetComponent<RectTransform>();
+        rt.anchorMin = Vector2.zero;
+        rt.anchorMax = Vector2.one;
+        rt.offsetMin = Vector2.zero;
+        rt.offsetMax = Vector2.zero;
+
+        return go.AddComponent<TextMeshProUGUI>();
+    }
+
+    private static void CreateTabButton(Transform parent, string name, string label)
+    {
+        GameObject btnGO = GetOrCreateChild(parent, name);
+        Image img = btnGO.GetComponent<Image>();
+        if (img == null) img = btnGO.AddComponent<Image>();
+        img.color = new Color(0.3f, 0.15f, 0.05f, 0.9f);
+
+        Button btn = btnGO.GetComponent<Button>();
+        if (btn == null) btn = btnGO.AddComponent<Button>();
+
+        TextMeshProUGUI text = GetOrCreateTMPChild(btnGO.transform, "Label");
+        text.text = label;
+        text.alignment = TextAlignmentOptions.Center;
+        text.fontSize = 18f;
+    }
+
+    private static void CreateOrUpdateCodexEntryButtonPrefab()
+    {
+#if UNITY_EDITOR
+        const string prefabPath = "Assets/Prefabs/CodexEntryBtn.prefab";
+
+        GameObject root = new GameObject("CodexEntryBtn", typeof(RectTransform));
+        RectTransform rt = root.GetComponent<RectTransform>();
+        rt.sizeDelta = new Vector2(0f, 50f);
+
+        Image img = root.AddComponent<Image>();
+        img.color = new Color(0.15f, 0.08f, 0.03f, 0.9f);
+
+        Button btn = root.AddComponent<Button>();
+
+        LayoutElement le = root.AddComponent<LayoutElement>();
+        le.minHeight = 50f;
+
+        // Icon
+        GameObject iconGO = CreateUIObject("Icon", root.transform);
+        RectTransform iconRT = iconGO.GetComponent<RectTransform>();
+        iconRT.anchorMin = new Vector2(0f, 0f);
+        iconRT.anchorMax = new Vector2(0f, 1f);
+        iconRT.pivot = new Vector2(0f, 0.5f);
+        iconRT.sizeDelta = new Vector2(40f, 0f);
+        iconRT.anchoredPosition = new Vector2(25f, 0f);
+
+        Image iconImg = iconGO.AddComponent<Image>();
+        iconImg.color = new Color(0f, 0f, 0f, 0.2f);
+
+        // Name label
+        TextMeshProUGUI nameText = GetOrCreateTMPChild(root.transform, "NameText");
+        RectTransform nameRT = nameText.rectTransform;
+        nameRT.anchorMin = new Vector2(0f, 0f);
+        nameRT.anchorMax = new Vector2(1f, 1f);
+        nameRT.offsetMin = new Vector2(70f, 5f);
+        nameRT.offsetMax = new Vector2(-10f, -5f);
+        nameText.alignment = TextAlignmentOptions.MidlineLeft;
+        nameText.text = "Codex Entry";
+
+        // Ensure folder exists
+        string folder = System.IO.Path.GetDirectoryName(prefabPath);
+        if (!System.IO.Directory.Exists(folder))
+        {
+            System.IO.Directory.CreateDirectory(folder);
+        }
+
+        PrefabUtility.SaveAsPrefabAsset(root, prefabPath);
+        Object.DestroyImmediate(root);
+#endif
+    }
+}
+#endif
